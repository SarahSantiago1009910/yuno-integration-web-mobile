PUBLIC_API_KEY=sandbox_gAAAAA************************************
PRIVATE_SECRET_KEY=gAAAAA************************************
CUSTOMER_ID=your-customer-id-here

# ===========================================
# Webhook (Optional)
# ===========================================
WEBHOOK_SECRET=

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=INFO
