# ===========================================
# Server Configuration
# ===========================================
NODE_ENV=development
PORT=8081
HOST=0.0.0.0
BASE_URL=http://localhost:8081

# ===========================================
# Yuno API - Sandbox Credentials
# ===========================================
# Get your credentials at: https://dashboard.y.uno
